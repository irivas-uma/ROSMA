function handles = create_matFile()

if exist('profiles.mat')
    load profiles
    str = strcat('profiles--',string(datetime('now')));
    save(str,'T')
end
    

T = table;
T.Id = {};
T.Name = {};
T.Surname = {};
T.Gender = {};
T.Age = {};

